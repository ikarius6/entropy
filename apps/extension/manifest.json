{
  "manifest_version": 3,
  "name": "Entropy Extension",
  "version": "0.1.0",
  "description": "Background seeding bridge for Entropy PoC.",
  "permissions": ["storage", "alarms", "idle", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inpage/nostr-provider.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "Entropy",
    "default_popup": "popup.html"
  },
  "options_page": "dashboard.html",
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "chunks/*", "inpage/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "entropy@entropy.local",
      "strict_min_version": "109.0"
    }
  }
}
