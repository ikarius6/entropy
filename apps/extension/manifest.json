{
  "manifest_version": 3,
  "name": "Entropy Extension",
  "version": "0.1.0",
  "description": "Background seeding bridge for Entropy PoC.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Entropy",
    "default_popup": "popup.html"
  },
  "options_page": "dashboard.html",
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "chunks/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
